---
import BaseLayout from "@layouts/BaseLayout.astro";
---
<BaseLayout title="Not found — Gorm." description="The page you wanted isn't here.">
  <section class="mx-auto max-w-page px-6 sm:px-8 py-24">
    <p class="gh-meta">404 · Not found</p>
    <h1 class="gh-section-title">This page isn't here.</h1>
    <p class="gh-lead mt-6">
      Either the URL is stale, or the page never existed. A few good places to land:
    </p>
    <ul class="gh-collection-list mt-8">
      <li class="mt-3"><a class="gh-arrow" href="/"><span class="gh-arrow-text">Home</span> <span class="glyph" aria-hidden="true">→</span></a></li>
      <li class="mt-3"><a class="gh-arrow" href="/work/"><span class="gh-arrow-text">All work</span> <span class="glyph" aria-hidden="true">→</span></a></li>
      <li class="mt-3"><a class="gh-arrow" href="/writing/"><span class="gh-arrow-text">All writing</span> <span class="glyph" aria-hidden="true">→</span></a></li>
      <li class="mt-3"><a class="gh-arrow" href="/contact/"><span class="gh-arrow-text">Contact</span> <span class="glyph" aria-hidden="true">→</span></a></li>
    </ul>
  </section>
</BaseLayout>
