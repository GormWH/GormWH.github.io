---
import MarkdownLayout from "@layouts/MarkdownLayout.astro";
import ArticleHeader from "@components/ArticleHeader.astro";
import ArticlePager from "@components/ArticlePager.astro";
import CollectionSidebar from "@components/CollectionSidebar.astro";
import CollectionToc from "@components/CollectionToc.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";
import { buildBlogPostingSchema, absoluteUrl, DEFAULT_OG_IMAGE } from "@lib/seo";

interface Props {
  entry: CollectionEntry<"writing">;
  next: CollectionEntry<"writing"> | null;
  all: CollectionEntry<"writing">[];
}

export const getStaticPaths: GetStaticPaths = async () => {
  const writings = (
    await getCollection("writing", ({ data }) =>
      import.meta.env.PROD ? !data.draft : true,
    )
  ).sort((a, b) => {
    const imp = Number(b.data.important) - Number(a.data.important);
    if (imp !== 0) return imp;
    const t = b.data.date.getTime() - a.data.date.getTime();
    if (t !== 0) return t;
    return a.id < b.id ? -1 : a.id > b.id ? 1 : 0;
  });

  return writings.map((entry, idx) => ({
    params: { slug: entry.id },
    props: { entry, next: writings[idx + 1] ?? null, all: writings },
  }));
};

const { entry, next, all } = Astro.props;
const { Content, headings } = await render(entry);

const date = entry.data.date.toISOString().slice(0, 10);
const tagsStr = entry.data.tags.join(" · ");
const metaGrid = [
  { label: "Date", value: date },
  { label: "Kind", value: entry.data.kind },
  ...(tagsStr ? [{ label: "Tags", value: tagsStr }] : []),
];

const writingJsonLd = buildBlogPostingSchema({
  url: absoluteUrl(Astro.url.pathname, Astro.site),
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.date,
  image: absoluteUrl(DEFAULT_OG_IMAGE, Astro.site),
});
---

<MarkdownLayout
  title={entry.data.title}
  description={entry.data.description}
  seo={{
    articleType: 'BlogPosting',
    jsonLd: writingJsonLd,
    publishedTime: entry.data.date.toISOString(),
    tags: entry.data.tags,
  }}
>
  <CollectionSidebar
    slot="left"
    entries={all}
    collection="writing"
    currentEntry={entry}
  />
  <CollectionToc slot="right" headings={headings} />

  <ArticleHeader
    back={{ href: "/writing/", label: "all writing" }}
    metaLeft={date}
    metaRight={entry.data.kind}
    title={entry.data.title}
    lead={entry.data.description}
    metaGrid={metaGrid}
  />
  <div class="gh-prose">
    <Content />
  </div>
  {
    next && (
      <ArticlePager
        next={{ href: `/writing/${next.id}/`, title: next.data.title }}
      />
    )
  }
</MarkdownLayout>
