---
import BaseLayout from "@layouts/BaseLayout.astro";
import { channels } from "../data/contact-channels";
---

<BaseLayout title="Contact — Gorm." description="Reach me on LinkedIn. I read everything; I reply to most things within a few days.">
  <div class="ct-page mx-auto max-w-page px-6 sm:px-8">

    <section class="ct-hero" aria-labelledby="ct-hero-h">
      <p class="gh-meta">Contact</p>
      <h1 id="ct-hero-h" class="gh-section-title">If it's worth doing,<br />I'd like to hear about it.</h1>
      <p class="gh-lead ct-lead">LinkedIn is the easiest way to reach me. I read everything; I reply to most things within a few days.</p>
    </section>

    <section class="ct-channels" aria-label="Contact channels">
      <ul class="ct-channels-list">
        {channels.map((c) => (
          <li class="ct-row">
            <a
              class="ct-row-link"
              href={c.href}
              target={c.external ? '_blank' : undefined}
              rel={c.external ? 'noopener noreferrer' : undefined}
            >
              <span class="ct-row-label gh-meta">{c.label}</span>
              <span class="ct-row-value">{c.value}</span>
              <span
                class:list={["ct-row-glyph", c.external && "ct-row-glyph-external"]}
                aria-hidden="true"
              >→</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="ct-where" aria-labelledby="ct-where-h">
      <div>
        <p class="gh-meta">Where</p>
        <h2 id="ct-where-h" class="gh-section-title ct-h2">Currently in Osaka, JP.</h2>
        <p class="ct-body">I work hybrid out of 大阪 — happy to meet for coffee if you're in the city, and most weeks I'm in Tokyo for a day or two.</p>
        <div class="ct-meta-grid">
          <div>
            <p class="gh-meta">Time zone</p>
            <p class="ct-meta-val">JST · UTC+9</p>
          </div>
          <div>
            <p class="gh-meta">Languages</p>
            <p class="ct-meta-val">EN · 日本語 · 한국어</p>
          </div>
          <div>
            <p class="gh-meta">Working hours</p>
            <p class="ct-meta-val">10:00 — 19:00 JST</p>
          </div>
        </div>
      </div>
      <div class="ct-map">
        <svg viewBox="0 0 400 300" preserveAspectRatio="xMidYMid slice" role="img" aria-label="Map highlighting Osaka, Japan">
          <defs>
            <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
              <path d="M 20 0 L 0 0 0 20" fill="none" stroke="var(--color-rule)" stroke-width="0.5"/>
            </pattern>
          </defs>
          <g aria-hidden="true">
            <rect width="400" height="300" fill="var(--color-bg-2)"/>
            <rect width="400" height="300" fill="url(#grid)"/>
            <path d="M 0,180 C 60,170 100,200 130,190 C 160,180 180,150 220,160 C 260,170 290,200 340,190 L 400,200 L 400,300 L 0,300 Z" fill="var(--color-rule)" opacity="0.5"/>
            <path d="M 0,180 C 60,170 100,200 130,190 C 160,180 180,150 220,160 C 260,170 290,200 340,190 L 400,200" fill="none" stroke="var(--color-ink-3)" stroke-width="1"/>
            <g transform="translate(195, 145)">
              <circle r="22" fill="var(--color-accent)" opacity="0.18"/>
              <circle r="12" fill="var(--color-accent)" opacity="0.32"/>
            </g>
          </g>
          <g transform="translate(195, 145)">
            <circle r="5" fill="var(--color-accent-ink)"/>
            <circle r="2" fill="var(--color-bg)"/>
          </g>
          <text x="210" y="142" font-family="JetBrains Mono, monospace" font-size="10" fill="var(--color-ink-1)" letter-spacing="1.2">OSAKA</text>
          <text x="210" y="155" font-family="JetBrains Mono, monospace" font-size="8" fill="var(--color-ink-2)">34.69° N · 135.50° E</text>
        </svg>
      </div>
    </section>

    <section class="ct-availability" aria-labelledby="ct-avail-h">
      <p id="ct-avail-h" class="gh-meta">Availability</p>
      <div class="ct-avail-row">
        <span class="ct-dot" aria-hidden="true"></span>
        <p class="ct-avail-text"><strong>Open to short collaborations</strong> · taking on 1–2 outside projects per quarter. Best fit: AI-tooling for engineering teams, mechanical/software-bridge work, technical writing.</p>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .ct-hero {
    padding: var(--space-80) 0 var(--space-48);
    max-width: 880px;
  }

  .ct-lead {
    margin-top: var(--space-24);
    color: var(--color-ink-2);
    max-width: 580px;
  }

  .ct-channels {
    padding: var(--space-24) 0;
    border-top: 1px solid var(--color-rule);
  }

  .ct-channels-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ct-row {
    border-bottom: 1px solid var(--color-rule);
  }

  .ct-row-link {
    display: grid;
    grid-template-columns: 140px 1fr 32px;
    gap: var(--space-24);
    padding: var(--space-22) 0;
    align-items: center;
    color: var(--color-ink-1);
    text-decoration: none;
    transition: padding-left var(--duration-base) var(--ease-mech);
    --ct-uc: transparent;
    --ct-glyph-x: 0;
    --ct-glyph-color: var(--color-ink-3);
  }

  .ct-row-link:hover {
    padding-left: var(--space-12);
    --ct-uc: var(--color-ink-1);
    --ct-glyph-x: var(--space-4);
    --ct-glyph-color: var(--color-ink-1);
  }

  .ct-row-label {
    color: var(--color-ink-3);
  }

  .ct-row-value {
    font-family: var(--font-headline);
    font-size: var(--text-22);
    font-weight: 500;
    letter-spacing: 0.005em;
    color: var(--color-ink-1);
    text-decoration: underline var(--ct-uc);
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: text-decoration-color var(--duration-base) var(--ease-mech);
  }

  .ct-row-glyph {
    font-family: var(--font-mono);
    font-size: var(--text-22);
    color: var(--ct-glyph-color);
    text-align: right;
    transform: translateX(var(--ct-glyph-x));
    transition: transform var(--duration-base) var(--ease-mech), color var(--duration-fast) var(--ease-mech);
  }

  .ct-row-glyph-external {
    transform: translateX(var(--ct-glyph-x)) rotate(-45deg);
  }

  .ct-where {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-64);
    padding: var(--space-96) 0;
    align-items: start;
    border-top: 1px solid var(--color-rule);
  }

  .ct-h2 {
    margin-top: var(--space-18);
    font-size: clamp(var(--text-28), 3.5vw, var(--text-40));
  }

  .ct-body {
    margin-top: var(--space-18);
    max-width: 480px;
    color: var(--color-ink-2);
  }

  .ct-meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-24);
    margin-top: var(--space-32);
  }

  .ct-meta-grid > div:nth-child(3) {
    grid-column: span 2;
    padding-top: var(--space-18);
    border-top: 1px solid var(--color-rule);
  }

  .ct-meta-val {
    font-family: var(--font-headline);
    font-size: var(--text-18);
    font-weight: 500;
    color: var(--color-ink-1);
    margin: var(--space-6) 0 0;
    letter-spacing: 0.01em;
  }

  .ct-map {
    aspect-ratio: 4/3;
    border-radius: var(--radius-2);
    border: 1px solid var(--color-rule);
    overflow: hidden;
    background: var(--color-bg-2);
  }

  .ct-map svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .ct-availability {
    padding: var(--space-48) 0;
    border-top: 1px solid var(--color-rule);
  }

  .ct-avail-row {
    display: flex;
    gap: var(--space-18);
    align-items: flex-start;
    margin-top: var(--space-22);
  }

  .ct-dot {
    flex-shrink: 0;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-accent);
    margin-top: var(--space-8);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 24%, transparent);
    animation: ct-pulse 2.4s ease-in-out infinite;
  }

  @keyframes ct-pulse {
    0%, 100% { box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 24%, transparent); }
    50% { box-shadow: 0 0 0 8px color-mix(in srgb, var(--color-accent) 8%, transparent); }
  }

  .ct-avail-text {
    font-size: var(--text-16);
    line-height: 1.65;
    color: var(--color-ink-1);
    max-width: 640px;
  }

  .ct-avail-text strong {
    font-weight: 600;
  }

  @media (max-width: 759px) {
    .ct-row-link {
      grid-template-columns: 1fr;
      gap: var(--space-6);
      padding: var(--space-18) 0;
    }

    .ct-row-glyph {
      display: none;
    }

    .ct-where {
      grid-template-columns: 1fr;
      gap: var(--space-32);
      padding: var(--space-64) 0;
    }

    .ct-meta-grid {
      grid-template-columns: 1fr;
    }

    .ct-meta-grid > div:nth-child(3) {
      grid-column: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ct-dot {
      animation: none;
    }

    .ct-row-link {
      transition: none;
    }

    .ct-row-glyph {
      transition: none;
    }

    .ct-row-value {
      transition: none;
    }
  }
</style>
