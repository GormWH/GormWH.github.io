---
import MarkdownLayout from "@layouts/MarkdownLayout.astro";
import ArticleHeader from "@components/ArticleHeader.astro";
import ArticlePager from "@components/ArticlePager.astro";
import CollectionSidebar from "@components/CollectionSidebar.astro";
import CollectionToc from "@components/CollectionToc.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";

interface Props {
  entry: CollectionEntry<"work">;
  next: CollectionEntry<"work"> | null;
  all: CollectionEntry<"work">[];
}

export const getStaticPaths: GetStaticPaths = async () => {
  const works = (
    await getCollection("work", ({ data }) =>
      import.meta.env.PROD ? !data.draft : true,
    )
  ).sort((a, b) => {
    const imp = Number(b.data.important) - Number(a.data.important);
    if (imp !== 0) return imp;
    const t = b.data.date.getTime() - a.data.date.getTime();
    if (t !== 0) return t;
    return a.id < b.id ? -1 : a.id > b.id ? 1 : 0;
  });

  return works.map((entry, idx) => ({
    params: { slug: entry.id },
    props: { entry, next: works[idx + 1] ?? null, all: works },
  }));
};

const { entry, next, all } = Astro.props;
const { Content, headings } = await render(entry);

const date = entry.data.date.toISOString().slice(0, 10);
const stack = entry.data.tags.join(" · ");
const metaGrid = [
  { label: "Date", value: date },
  { label: "Org", value: entry.data.org },
  ...(stack ? [{ label: "Stack", value: stack }] : []),
];
---

<MarkdownLayout title={entry.data.title} description={entry.data.description}>
  <CollectionSidebar
    slot="left"
    entries={all}
    collection="work"
    currentEntry={entry}
  />
  <CollectionToc slot="right" headings={headings} />

  <ArticleHeader
    back={{ href: "/work/", label: "all work" }}
    metaLeft={date}
    metaRight={entry.data.org}
    title={entry.data.title}
    lead={entry.data.description}
    metaGrid={metaGrid}
  />
  <div class="gh-prose">
    <Content />
  </div>
  {
    next && (
      <ArticlePager
        next={{ href: `/work/${next.id}/`, title: next.data.title }}
      />
    )
  }
</MarkdownLayout>
