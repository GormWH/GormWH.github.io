---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const works = (
  await getCollection("work", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  )
).sort((a, b) => {
  const imp = Number(b.data.important) - Number(a.data.important);
  if (imp !== 0) return imp;
  const t = b.data.date.getTime() - a.data.date.getTime();
  if (t !== 0) return t;
  return a.id < b.id ? -1 : a.id > b.id ? 1 : 0;
});
---

<BaseLayout>
  <section class="mx-auto max-w-page px-6 sm:px-8 py-16">
    <header class="mb-10">
      <p class="gh-section-label">Work</p>
      <h1 class="gh-section-title">All projects</h1>
    </header>

    {
      works.length === 0 ? (
        <p>No work entries yet.</p>
      ) : (
        <ul class="work-list">
          {works.map((entry) => (
            <li class="work-item">
              <a class="work-item-link" href={`/work/${entry.id}/`}>
                <p class="gh-meta">
                  {entry.data.date.getFullYear()} · {entry.data.org}
                </p>
                <h2 class="work-item-title">{entry.data.title}</h2>
                <p class="work-item-desc">{entry.data.description}</p>
                {entry.data.tags.length > 0 && (
                  <div class="work-item-tags">
                    {entry.data.tags.map((t) => (
                      <span class="hp-tag">{t}</span>
                    ))}
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>

<style>
  .work-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-rule);
  }
  .work-item {
    border-bottom: 1px solid var(--color-rule);
  }
  .work-item-link {
    display: block;
    padding: 22px 0;
    color: inherit;
    text-decoration: none;
    transition: background var(--duration-fast) var(--ease-mech);
  }
  .work-item-link:hover {
    background: var(--color-bg-2);
  }
  .work-item-title {
    font-family: var(--font-headline);
    font-size: 22px;
    line-height: 1.2;
    font-weight: 500;
    margin: 8px 0 6px;
    color: var(--color-ink-1);
  }
  .work-item-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-ink-2);
    margin: 0 0 10px;
  }
  .work-item-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
</style>
