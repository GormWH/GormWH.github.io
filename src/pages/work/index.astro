---
import BaseLayout from "@layouts/BaseLayout.astro";
import TagFilter from "@components/TagFilter.astro";
import CollectionList from "@components/CollectionList.astro";
import { getCollection } from "astro:content";
import { collectTags } from "@lib/tagFilter";

const works = (
  await getCollection("work", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  )
).sort((a, b) => {
  const imp = Number(b.data.important) - Number(a.data.important);
  if (imp !== 0) return imp;
  const t = b.data.date.getTime() - a.data.date.getTime();
  if (t !== 0) return t;
  return a.id < b.id ? -1 : a.id > b.id ? 1 : 0;
});

const tags = collectTags(works);
---

<BaseLayout>
  <section class="mx-auto max-w-page px-6 sm:px-8 py-16">
    <header class="mb-10">
      <p class="gh-meta">
        Work · <span data-tag-filter-count>{works.length}</span>
      </p>
      <h1 class="gh-section-title">All projects</h1>
    </header>

    {
      works.length === 0 ? (
        <p>No work entries yet.</p>
      ) : (
        <div data-tag-filter-root data-collection="work">
          <TagFilter tags={tags} variant="listing" />
          <CollectionList
            entries={works}
            collection="work"
            variant="listing"
          />
        </div>
      )
    }
  </section>
</BaseLayout>
