---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

function compareWork(a: CollectionEntry<"work">, b: CollectionEntry<"work">) {
  const imp = Number(b.data.important) - Number(a.data.important);
  if (imp !== 0) return imp;
  const t = b.data.date.getTime() - a.data.date.getTime();
  if (t !== 0) return t;
  return a.id < b.id ? -1 : a.id > b.id ? 1 : 0;
}

const all = await getCollection("work", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);
const works = all.sort(compareWork).slice(0, 4);
---

<section id="home-work" class="gh-section mx-auto max-w-page px-6 sm:px-8">
  <header class="gh-section-head">
    <div>
      <p class="gh-meta">02 — Work</p>
      <h2 class="gh-section-title">Recent work</h2>
    </div>
    <a class="gh-arrow" href="/work/">
      <span class="gh-arrow-text">all projects</span>
      <span class="glyph" aria-hidden="true">→</span>
    </a>
  </header>

  <div class="hp-work-grid">
    {
      works.map((entry) => (
        <a class="hp-work-card" href={`/work/${entry.id}/`}>
          <p class="gh-meta hp-work-meta">{entry.data.date.getFullYear()} · {entry.data.org}</p>
          <h3 class="hp-work-title">{entry.data.title}</h3>
          <p class="hp-work-desc">{entry.data.description}</p>
          <div class="hp-work-tags">
            {entry.data.tags.map((t) => (
              <span class="gh-pill">{t}</span>
            ))}
          </div>
        </a>
      ))
    }
  </div>
</section>

<style>
  .hp-work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-rule);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-2);
    overflow: hidden;
  }

  .hp-work-card {
    display: block;
    padding: var(--space-28) 30px; /* nudge: 30px horizontal off-scale, deliberate card breathing-room */
    background: var(--color-bg);
    transition: background var(--duration-fast) var(--ease-mech);
    --hp-work-uc: transparent;
  }

  .hp-work-card:hover {
    background: var(--color-bg-2);
    --hp-work-uc: var(--color-ink-1);
  }

  .hp-work-meta {
    margin-bottom: var(--space-14);
  }

  .hp-work-title {
    font-family: var(--font-headline);
    font-size: var(--text-22);
    line-height: 1.2;
    letter-spacing: 0.005em;
    font-weight: 500;
    color: var(--color-ink-1);
    margin: 0 0 var(--space-10);
    text-decoration: underline var(--hp-work-uc);
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: text-decoration-color var(--duration-fast) var(--ease-mech);
  }

  .hp-work-desc {
    font-size: var(--text-15);
    line-height: 1.6;
    color: var(--color-ink-2);
    margin: 0 0 var(--space-18);
  }

  .hp-work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
  }

  @media (max-width: 760px) {
    .hp-work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
