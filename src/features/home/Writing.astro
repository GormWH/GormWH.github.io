---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

function compareWriting(
  a: CollectionEntry<"writing">,
  b: CollectionEntry<"writing">,
) {
  const imp = Number(b.data.important) - Number(a.data.important);
  if (imp !== 0) return imp;
  const t = b.data.date.getTime() - a.data.date.getTime();
  if (t !== 0) return t;
  return a.id < b.id ? -1 : a.id > b.id ? 1 : 0;
}

const all = await getCollection("writing", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);
const writings = all.sort(compareWriting).slice(0, 4);
---

<section id="home-writing" class="gh-section mx-auto max-w-page px-6 sm:px-8">
  <header class="gh-section-head">
    <div>
      <p class="gh-meta">03 — Writing</p>
      <h2 class="gh-section-title">Notes from the bench</h2>
    </div>
    <a class="gh-arrow" href="/writing">
      <span class="gh-arrow-text">all writing</span>
      <span class="glyph" aria-hidden="true">→</span>
    </a>
  </header>

  <p class="hp-writing-intro">
    I write to think out loud — short notes from the work, longer essays when
    something earns the airtime.
  </p>

  <ol class="hp-writing-list">
    {
      writings.map((entry) => (
        <li class="gh-meta-row hp-writing-row">
          <p class="hp-writing-year">{entry.data.date.getFullYear()}</p>
          <div class="hp-writing-body">
            <a class="hp-writing-link" href={`/writing/${entry.id}/`}>
              <h3 class="hp-writing-title">{entry.data.title}</h3>
            </a>
            <p class="hp-writing-summary">{entry.data.description}</p>
            <span class="gh-pill hp-writing-kind">{entry.data.kind}</span>
          </div>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .hp-writing-intro {
    font-size: var(--text-16);
    line-height: 1.7;
    color: var(--color-ink-1);
    max-width: 60ch;
    margin: 0 0 var(--space-32);
  }

  .hp-writing-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .hp-writing-row {
    grid-template-columns: 120px 1fr;
    gap: var(--space-24);
    padding: var(--space-18) 0;
  }

  .hp-writing-year {
    font-family: var(--font-mono);
    font-size: var(--text-12);
    color: var(--color-ink-3);
    letter-spacing: 0.04em;
    margin: 0;
  }

  .hp-writing-body {
    max-width: 60ch;
  }

  .hp-writing-link {
    color: inherit;
    text-decoration: none;
    --hp-writing-uc: transparent;
  }

  .hp-writing-link:hover {
    --hp-writing-uc: var(--color-ink-1);
  }

  .hp-writing-title {
    font-family: var(--font-headline);
    font-size: var(--text-20);
    line-height: 1.25;
    font-weight: 500;
    color: var(--color-ink-1);
    margin: 0;
    text-decoration: underline var(--hp-writing-uc);
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: text-decoration-color var(--duration-fast) var(--ease-mech);
  }

  .hp-writing-summary {
    font-size: var(--text-15);
    line-height: 1.6;
    color: var(--color-ink-2);
    margin: var(--space-8) 0 0;
  }

  .hp-writing-kind {
    display: inline-block;
    margin-top: var(--space-10);
  }

  @media (max-width: 760px) {
    .hp-writing-row {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
