---
const WRITING: {
  date: Date;
  title: string;
  kind: "Note" | "Essay" | "Log";
  summary: string;
}[] = [
  {
    date: new Date("2026-01-18"),
    title: "Why I write the tools instead of just using them",
    kind: "Note",
    summary:
      "Notes from the bench at bitset, where most of my AI tooling starts as a half-formed script before it earns a name.",
  },
  {
    date: new Date("2025-09-04"),
    title: "From CFD meshes to commit graphs",
    kind: "Essay",
    summary:
      "Software engineering rewards the same pattern recognition I used to chase numerical instabilities — different vocabulary, identical instinct.",
  },
  {
    date: new Date("2025-04-22"),
    title: "The signaller's lesson",
    kind: "Note",
    summary:
      "Two years as a signaller in the ROK Army taught me the wire isn't the protocol — the protocol is the people on either end of it.",
  },
  {
    date: new Date("2024-11-09"),
    title: "Re-reading my master's thesis after three years",
    kind: "Log",
    summary:
      "Three years out of grad school I went back and read my own thesis. Some of it still holds. Some of it I'd cut entirely.",
  },
];
---

<section id="home-writing" class="gh-section mx-auto max-w-page px-6 sm:px-8">
  <header class="gh-section-head">
    <div>
      <p class="gh-meta">03 — Writing</p>
      <h2 class="gh-section-title">Notes from the bench</h2>
    </div>
    <a class="gh-arrow" href="#">
      <span class="gh-arrow-text">all writing</span>
      <span class="glyph" aria-hidden="true">→</span>
    </a>
  </header>

  <p class="hp-writing-intro">
    I write to think out loud — short notes from the work, longer essays when
    something earns the airtime.
  </p>

  <ol class="hp-writing-list">
    {
      WRITING.map((w) => (
        <li class="gh-meta-row hp-writing-row">
          <p class="hp-writing-year">{w.date.getFullYear()}</p>
          <div class="hp-writing-body">
            <h3 class="hp-writing-title">{w.title}</h3>
            <p class="hp-writing-summary">{w.summary}</p>
            <span class="gh-pill hp-writing-kind">{w.kind}</span>
          </div>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .hp-writing-intro {
    font-size: var(--text-16);
    line-height: 1.7;
    color: var(--color-ink-1);
    max-width: 60ch;
    margin: 0 0 var(--space-32);
  }

  .hp-writing-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .hp-writing-row {
    grid-template-columns: 120px 1fr;
    gap: var(--space-24);
    padding: var(--space-18) 0;
  }

  .hp-writing-year {
    font-family: var(--font-mono);
    font-size: var(--text-12);
    color: var(--color-ink-3);
    letter-spacing: 0.04em;
    margin: 0;
  }

  .hp-writing-body {
    max-width: 60ch;
  }

  .hp-writing-title {
    font-family: var(--font-headline);
    font-size: var(--text-20);
    line-height: 1.25;
    font-weight: 500;
    color: var(--color-ink-1);
    margin: 0;
  }

  .hp-writing-summary {
    font-size: var(--text-15);
    line-height: 1.6;
    color: var(--color-ink-2);
    margin: var(--space-8) 0 0;
  }

  .hp-writing-kind {
    display: inline-block;
    margin-top: var(--space-10);
  }

  @media (max-width: 760px) {
    .hp-writing-row {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
