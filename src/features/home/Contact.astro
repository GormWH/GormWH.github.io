---
import { channels } from "../../data/contact-channels";
// Channel set is shared with /contact/ (src/data/contact-channels.ts); presentation diverges by design — see .omc/improvements/01-fix-dead-links-and-ctas.md.
---

<section id="home-contact" class="gh-section mx-auto max-w-page px-6 sm:px-8">
  <header class="gh-section-head">
    <div>
      <p class="gh-meta">04 — Contact</p>
      <h2 class="gh-section-title">
        If it's worth doing,<br />I'd like to hear about it.
      </h2>
    </div>
  </header>

  <div class="hp-contact-grid">
    {
      channels.map((c) => (
        <div>
          <p class="gh-meta hp-contact-cell-label">{c.label}</p>
          <a
            class="gh-arrow"
            href={c.href}
            target={c.external ? "_blank" : undefined}
            rel={c.external ? "noopener noreferrer" : undefined}
          >
            <span class="gh-arrow-text">{c.value}</span>
            <span class="glyph" aria-hidden="true">→</span>
          </a>
        </div>
      ))
    }
  </div>
</section>

<style>
  .hp-contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-32);
  }

  .hp-contact-cell-label {
    margin-bottom: var(--space-8);
  }

  @media (max-width: 760px) {
    .hp-contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-24);
    }
  }
</style>
