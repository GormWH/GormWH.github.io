---
const TIMELINE = [
  {
    years: "2023.07 — present",
    org: "株式会社bitset",
    role: "Software & systems engineer",
  },
  {
    years: "2021.04 — 2023.03",
    org: "University of Tokyo",
    role: "M.S. Mechanical Engineering",
  },
  {
    years: "2019.08 — 2021.02",
    org: "Republic of Korea Army",
    role: "Sergeant — Signaller",
  },
  {
    years: "2015.04 — 2019.03",
    org: "Osaka University",
    role: "B.S. Mechanical Engineering",
  },
];

const INITIAL_VISIBLE = 4;
const hasOverflow = TIMELINE.length > INITIAL_VISIBLE;
---

<section id="home-about" class="gh-section mx-auto max-w-page px-6 sm:px-8">
  <header class="gh-section-head">
    <div>
      <p class="gh-meta">01 — About</p>
      <h2 class="gh-section-title">A few things about me</h2>
    </div>
  </header>

  <div class="hp-about-grid">
    <div class="hp-about-prose">
      <p class="hp-about-body">
        I started in mechanical engineering — at Osaka University, then a
        master's at the University of Tokyo. Between those I served as a
        signaller in the ROK Army, where I learned that most problems are
        communication problems with extra steps.
      </p>
      <p class="hp-about-body">
        I picked up software because I needed it. The hardware side was fine;
        the tooling around it wasn't. So I learned to write the tools myself,
        and now I build AI-driven tooling at
        <a class="hp-about-link" href="https://bitset.jp/" target="_blank" rel="noopener noreferrer">株式会社bitset</a>.
      </p>
      <p class="hp-about-body hp-about-emphasis">
        I don't pick problems based on what I studied. I pick them because
        they're worth doing.
      </p>
    </div>

    <div class="hp-timeline" data-expanded="false">
      <p class="gh-meta hp-timeline-label">Timeline</p>
      {
        TIMELINE.map((t, i) => (
          <div class:list={["gh-meta-row hp-timeline-row", i >= INITIAL_VISIBLE && "is-overflow"]}>
            <p class="hp-timeline-years">{t.years}</p>
            <div>
              <p class="hp-timeline-org">{t.org}</p>
              <p class="hp-timeline-role">{t.role}</p>
            </div>
          </div>
        ))
      }
      {
        hasOverflow && (
          <button
            type="button"
            class="hp-timeline-toggle"
            data-timeline-toggle
            aria-expanded="false"
          >
            <span data-toggle-label-show>
              Show more <span aria-hidden="true">→</span>
            </span>
            <span data-toggle-label-hide hidden>Show less</span>
          </button>
        )
      }
    </div>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>(".hp-timeline[data-expanded]");
  const btn = root?.querySelector<HTMLButtonElement>("[data-timeline-toggle]");
  if (root && btn) {
    btn.addEventListener("click", () => {
      const willExpand = root.dataset.expanded !== "true";
      root.dataset.expanded = String(willExpand);
      btn.setAttribute("aria-expanded", String(willExpand));
      const showLabel = btn.querySelector<HTMLElement>("[data-toggle-label-show]");
      const hideLabel = btn.querySelector<HTMLElement>("[data-toggle-label-hide]");
      if (showLabel) showLabel.hidden = willExpand;
      if (hideLabel) hideLabel.hidden = !willExpand;
    });
  }
</script>

<style>
  .hp-about-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-64);
  }

  .hp-about-prose {
    max-width: 60ch;
  }

  .hp-about-body {
    font-size: var(--text-16);
    line-height: 1.7;
    color: var(--color-ink-1);
    margin: 0 0 var(--space-18);
  }

  .hp-about-body:last-child {
    margin-bottom: 0;
  }

  .hp-about-link {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--color-rule-strong);
    transition: text-decoration-color var(--duration-fast) var(--ease-mech);
  }

  .hp-about-link:hover {
    text-decoration-color: var(--color-ink-1);
  }

  .hp-about-emphasis {
    color: var(--color-ink-2);
    font-weight: 500;
  }

  .hp-timeline-label {
    margin-bottom: var(--space-18);
  }

  .hp-timeline-row {
    grid-template-columns: 160px 1fr;
    gap: var(--space-18);
    padding: var(--space-14) 0;
  }

  .hp-timeline-years {
    font-family: var(--font-mono);
    font-size: var(--text-12);
    color: var(--color-ink-3);
    letter-spacing: 0.04em;
    margin: 0;
  }

  .hp-timeline-org {
    font-size: var(--text-15);
    color: var(--color-ink-1);
    font-weight: 500;
    margin: 0;
  }

  .hp-timeline-role {
    font-size: var(--text-13);
    color: var(--color-ink-2);
    margin: 2px 0 0; /* nudge: 2px tight role-under-org offset */
  }

  .hp-timeline[data-expanded="false"] .hp-timeline-row.is-overflow {
    display: none;
  }

  .hp-timeline-toggle {
    margin-top: 0;
    padding: var(--space-12) 0;
    width: 100%;
    background: none;
    border: 0;
    border-top: 1px solid var(--color-rule);
    text-align: left;
    font-family: var(--font-mono);
    font-size: var(--text-12);
    letter-spacing: 0.04em;
    color: var(--color-ink-3);
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-mech);
  }

  .hp-timeline-toggle:hover {
    color: var(--color-ink-1);
  }

  @media (max-width: 760px) {
    .hp-about-grid {
      grid-template-columns: 1fr;
      gap: var(--space-48);
    }
    .hp-timeline-row {
      grid-template-columns: 120px 1fr;
      gap: var(--space-12);
    }
  }
</style>
