---
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const navItems = [
  { label: "About", href: "/#home-about" },
  { label: "Work", href: "/work" },
  { label: "Writing", href: "/writing" },
  { label: "Contact", href: "/contact" },
];
const isActive = (href: string) => {
  if (href.startsWith("/#")) return pathname === "/";
  const base = href.replace(/\/$/, "");
  // pathname is pre-normalized at line 2 (no trailing slash). The startsWith branch
  // makes section-parent links match sub-routes (e.g. /work/<slug>); do NOT collapse
  // back to exact-match.
  return pathname === base || pathname.startsWith(base + "/");
};
---

<header class="gh-header">
  <a href="/" class="font-headline text-22 text-ink-1">
    Gorm<span class="text-accent">.</span>
  </a>
  <nav class="gh-nav ml-auto font-body text-sm text-ink-1" aria-label="Primary">
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class="gh-link"
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
