---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageSection from "@components/ui/PageSection.astro";
import TextLink from "@components/ui/TextLink.astro";
import { useTranslations } from "@i18n/utils";
import type { Lang } from "@i18n/translations";

const lang = (Astro.currentLocale ?? "en") as Lang;
const t = useTranslations(lang);
---

<BaseLayout pageTitle={t("page.contact")}>
    <PageSection id="contact" title={t("contact.sectionTitle")}>
        <p>
            {t("contact.p1Lead")}{" "}
            <TextLink href="https://bitset.jp/" external={true}>株式会社bitset</TextLink>,{" "}
            {t("contact.p1Tail")}
        </p>
        <p>{t("contact.p2")}</p>
        <p>
            <TextLink
                href="https://www.linkedin.com/in/su-hong-park-1aa107216/"
                external={true}
                className="inline-flex items-center gap-1.5"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="h-4 w-4"
                    aria-hidden="true"
                >
                    <path
                        d="M6.94 8.5a1.56 1.56 0 1 1 0-3.12 1.56 1.56 0 0 1 0 3.12ZM8.5 10H5.38v8.62H8.5V10Zm5 0h-3.1v8.62h3.1v-4.7c0-2.62 3.4-2.84 3.4 0v4.7H20V12.8c0-4.53-4.94-4.36-6.5-2.13V10Z"
                    />
                </svg>
                LinkedIn
            </TextLink>
        </p>
        <p>
            <TextLink
                href="https://github.com/GormWH"
                external={true}
                className="inline-flex items-center gap-1.5"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="h-4 w-4"
                    aria-hidden="true"
                >
                    <path
                        d="M12 .5a11.5 11.5 0 0 0-3.64 22.41c.58.11.8-.25.8-.56v-2.16c-3.25.71-3.93-1.39-3.93-1.39-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.7.08-.7 1.17.08 1.78 1.2 1.78 1.2 1.03 1.77 2.71 1.26 3.38.96.1-.75.4-1.26.73-1.55-2.6-.3-5.33-1.3-5.33-5.8 0-1.28.46-2.32 1.2-3.14-.12-.3-.52-1.5.12-3.12 0 0 .98-.31 3.2 1.2A11.1 11.1 0 0 1 12 6.09a11.1 11.1 0 0 1 2.91.39c2.22-1.51 3.2-1.2 3.2-1.2.64 1.62.24 2.82.12 3.12.75.82 1.2 1.86 1.2 3.14 0 4.5-2.73 5.5-5.34 5.79.42.36.8 1.08.8 2.18v3.24c0 .31.21.67.81.56A11.5 11.5 0 0 0 12 .5Z"
                    />
                </svg>
                GitHub
            </TextLink>
        </p>
    </PageSection>
</BaseLayout>
